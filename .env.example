# MySQL Configuration
# Copy this file to .env and update with your actual credentials
# Reference this file in documentation so developers know what environment variables are needed

MYSQL_DATABASE=little_lemon_portfolio
MYSQL_USER=your_db_user
MYSQL_PASSWORD=your_db_password
MYSQL_HOST=localhost
MYSQL_PORT=3306

# API Configuration
API_PORT=3001
NODE_ENV=development
